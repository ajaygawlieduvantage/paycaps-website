# Copy to `.env.local` — restart both `npm run dev` and `npm run studio` after changes

# Next.js site
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-07-01

# Sanity Studio (same values; Studio only reads SANITY_STUDIO_*)
SANITY_STUDIO_PROJECT_ID=your_project_id_here
SANITY_STUDIO_DATASET=production
SANITY_STUDIO_API_VERSION=2024-07-01

# Optional: read token for draft preview (server-only)
# SANITY_API_READ_TOKEN=

# CORS: http://localhost:3000 (site) and http://localhost:3333 (studio)

# Strapi API URL Configuration
# NEXT_PUBLIC_STRAPI_API_URL=http://localhost:1337
NEXT_PUBLIC_STRAPI_API_URL=https://sacred-badge-63efd6a131.strapiapp.com

